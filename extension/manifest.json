{
  "manifest_version": 3,
  "name": "Phishing Shield Enterprise",
  "version": "2.0",
  "description": "Protección impulsada por IA.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*/*",
    "http://127.0.0.1:8000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}